{% extends '@AdminBundle/base.html.twig' %}

{% block title %}Waardering{% endblock %}

{% block content %}
    <table class="table table-striped">
        {% for review in reviews %}
            <tr>
                <td>{{ review.content }}</td>
                <td><a href="{{ path('admin_rating_edit', {'id': review.id}) }}">wijzig</a></td>
            </tr>
        {% endfor %}
    </table>
{% endblock %}
