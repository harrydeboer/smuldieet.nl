<div id="form-errors-client"></div>
<div id="form-errors-server">
    {{ form_errors(form) }}
    {{ form_errors(form.title) }}
    {{ form_errors(form.slug) }}
    {{ form_errors(form.summary) }}
    {{ form_errors(form.content) }}
</div>
{{ form_start(form) }}
<div class="fw-bold">Titel</div>
{{ form_widget(form.title) }}
<div class="fw-bold">Slug</div>
{{ form_widget(form.slug) }}
<div class="fw-bold">Samenvatting</div>
{{ form_widget(form.summary) }}
<div class="fw-bold">Content</div>
{{ form_widget(form.content) }}
<div>{{ form_widget(form.submit, { 'label': submitLabel }) }}</div>
{{ form_end(form) }}
