{% extends '@AdminBundle/base.html.twig' %}

{% block title %}Pagina{% endblock %}

{% block body %}
    <a href="{{ path('admin_page_create') }}">Maak een pagina</a>
    <table class="table table-striped">
        {% for page in pages %}
            <tr>
                <td>{{ page.title }}</td>
                <td><a href="{{ path('admin_page_edit', {'id': page.id}) }}">wijzig</a></td>
            </tr>
        {% endfor %}
    </table>
{% endblock %}
