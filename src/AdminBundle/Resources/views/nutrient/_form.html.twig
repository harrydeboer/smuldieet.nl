<div id="form_errors_client"></div>
<div id="form_errors_server">
    {{ form_errors(form) }}
    {{ form_errors(form.display_name) }}
    {{ form_errors(form.min_rda) }}
    {{ form_errors(form.max_rda) }}
    {{ form_errors(form.unit) }}
    {{ form_errors(form.decimal_places) }}
</div>
{{ form_start(form) }}
 {% for message in app.flashes('error') %}
     <div class="flash-notice-error">
         {{ message }}
     </div>
 {% endfor %}
{% set classes = form.unit.vars.attr.class %}
{% if nutrient.name != 'energy' %}
    {% set classes = classes~' not-energy' %}
{% else %}
    {% set classes = classes~' not-solid not-vitamin-mineral' %}
{% endif %}
{% if nutrient.name != 'water' %}
    {% set classes = classes~' not-liquid' %}
{% endif %}
<table class="table table-small">
    <tr>
        <td>Naam</td><td>{{ nutrient.name }}</td>
    </tr>
    <tr>
        <td>Weergave naam</td><td>{{ form_widget(form.display_name) }}</td>
    </tr>
    <tr>
        <td>Minimum ADH</td><td>{{ form_widget(form.min_rda) }}</td>
    </tr>
    <tr>
        <td>Maximum ADH</td><td>{{ form_widget(form.max_rda) }}</td>
    </tr>
    <tr>
        <td>Unit</td><td>{{ form_widget(form.unit, {'attr':{'class':classes}}) }}</td>
    </tr>
    <tr>
        <td>Aantal decimalen</td><td>{{ form_widget(form.decimal_places) }}</td>
    </tr>
    <tr>
        <td colspan="2">{{ form_widget(form.submit, { 'label': submit_label }) }}</td>
    </tr>
</table>
{{ form_end(form) }}
