    {{ form_errors(form.energyKcal) }}
    {{ form_errors(form.water) }}
    {{ form_errors(form.protein) }}
    {{ form_errors(form.carbohydrates) }}
    {{ form_errors(form.sucre) }}
    {{ form_errors(form.fat) }}
    {{ form_errors(form.saturatedFat) }}
    {{ form_errors(form.monounsaturatedFat) }}
    {{ form_errors(form.polyunsaturatedFat) }}
    {{ form_errors(form.cholesterol) }}
    {{ form_errors(form.dietaryFiber) }}
    {{ form_errors(form.salt) }}
    {{ form_errors(form.vitaminA) }}
    {{ form_errors(form.vitaminB1) }}
    {{ form_errors(form.vitaminB2) }}
