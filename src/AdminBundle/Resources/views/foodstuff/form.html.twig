<div id="form-errors-client"></div>
<div id="form-errors-server">
    {{ form_errors(form) }}
    {{ form_errors(form.user) }}
    {{ form_errors(form.name) }}
    {% for key,property in foodstuff.aDH() %}
        {{ form_errors(attribute(form, key)) }}
    {% endfor %}
</div>
{{ form_start(form) }}
<table class="foodstuff-recipe-table table table-small">
    <tr><td>Gebruiker</td><td>{{ form_widget(form.user) }}</td></tr>
    <tr><td>Naam</td><td>{{ form_widget(form.name) }}</td></tr>
    <tr><td>Gewicht per stuk</td><td>{{ form_widget(form.pieceWeight) }}</td></tr>
    <tr><td>Naam per stuk</td><td>{{ form_widget(form.pieceName) }}</td></tr>
    {% for key,property in foodstuff.aDH() %}
        <tr><td>{{ property[3] }}</td><td>{{ form_widget(attribute(form, key)) }}</td></tr>
    {% endfor %}
    <tr><td colspan="2">{{ form_widget(form.submit, { 'label': submitLabel }) }}</td></tr>
</table>
{{ form_end(form) }}
