    {{ form_errors(form.vitaminB6) }}
    {{ form_errors(form.vitaminB11) }}
    {{ form_errors(form.vitaminB12) }}
    {{ form_errors(form.vitaminC) }}
    {{ form_errors(form.vitaminD) }}
    {{ form_errors(form.vitaminE) }}
    {{ form_errors(form.vitaminK) }}
    {{ form_errors(form.potassium) }}
    {{ form_errors(form.calcium) }}
