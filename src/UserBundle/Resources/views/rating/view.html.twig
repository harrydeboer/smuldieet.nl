{% extends '@UserBundle/base.html.twig' %}

{% block title %}Waarderingen{% endblock %}

{% block body %}
    <h1>Waarderingen</h1>
    <table class="table table-striped">
        <thead>
        <tr>
            <th scope="col">Waardering</th>
            <th scope="col">Wijzig</th>
        </tr>
        </thead>
        {% for rating in ratings %}
            <tr>
                <td><a href="{{ path('rating_single', {'id': rating.id}) }}">
                        {{ rating.recipe.title }}</a> {{ rating.rating }} <i class="fas fa-star fa-star-gold"></i></td>
                <td><a href="{{ path('user_rating_edit', {'id': rating.id }) }}">wijzig</a></td>
            </tr>
        {% endfor %}
    </table>
{% endblock %}
