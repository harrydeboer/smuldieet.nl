{% extends '@UserBundle/base.html.twig' %}

{% block title %}Recensie{% endblock %}

{% block body %}
    <table class="table table-small">
        <tr>
            <td>Username</td>
            <td>{{ rating.user.username }}</td>
        </tr>
        <tr>
            <td>Datum</td>
            <td>{{ rating.date|date('d-M-Y') }}</td>
        </tr>
        <tr>
            <td>Waardering</td>
            <td>{{ rating.rating }}</td>
        </tr>
        <tr>
            <td>Recensie</td>
            <td>{{ rating.content }}</td>
        </tr>
        <tr>
            <td colspan="2"><a href="{{ path('user_review_edit', {'id': rating.id}) }}">wijzig</a></td>
        </tr>
    </table>
{% endblock %}
