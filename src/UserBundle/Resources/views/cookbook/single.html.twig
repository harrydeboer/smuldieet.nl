{% extends '@UserBundle/base.html.twig' %}

{% block title %}Kookboek{% endblock %}

{% block body %}
    <table class="table table-small">
        <tr>
            <td>Titel</td>
            <td>{{ cookbook.title }}</td>
        </tr>
        {% for weight in cookbook.recipeWeights %}
            <tr>
                <td colspan="2">{{ weight.recipe.title }}</td>
            </tr>
        {% endfor %}
        <tr>
            <td colspan="2">
                <a href="{{ path('user_cookbook_edit', {'id': cookbook.id}) }}">wijzig</a>
            </td>
        </tr>
    </table>
{% endblock %}
