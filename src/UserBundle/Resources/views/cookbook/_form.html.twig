<div id="form_errors_client"></div>
<div id="form_errors_server">
    {{ form_errors(form) }}
    {{ form_errors(form.title) }}
    {{ form_errors(form.recipe_weights) }}
</div>
{{ form_start(form, { 'attr' : { 'class': 'recipe-weights-form' }}) }}
<table class="food-table table table-small">
    <tr>
        <td>Titel</td>
        <td colspan="3">{{ form_widget(form.title) }}</td>
    </tr>
    {{ include('_recipe_weights.html.twig', {
        'form_name': 'cookbook',
        'recipe_weights': cookbook.recipeWeights,
        'weights': form.recipe_weights
    }) }}
    <tr id="add_foodstuff_recipe_button_row">
        <td colspan="4"><div class="btn btn-primary" id="add_recipe">Recept toevoegen</div></td>
    </tr>
    <tr>
        <td colspan="3">{{ form_widget(form.submit, { 'label': submit_label }) }}</td>
    </tr>
</table>
{{ form_end(form) }}
