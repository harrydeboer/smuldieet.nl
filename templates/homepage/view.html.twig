{% extends 'base.html.twig' %}

{% block title %}{{ page is not null ? page.title : '' }}{% endblock %}

{% block body %}
    {% for message in app.flashes('success') %}
        <div class="flash-notice-success">
            {{ message }}
        </div>
    {% endfor %}
    {% for message in app.flashes('mustVerify') %}
        <div class="flash-notice-must-verify">
            {{ message }}
        </div>
    {% endfor %}
    {{ page is not null ? page.content|raw : '' }}
    <div id="form-errors-client"></div>
    <div id="form-errors-server">
        {{ form_errors(form) }}
        {{ form_errors(form.title) }}
        {{ form_errors(form.typeOfDish) }}
        {{ form_errors(form.cookingTime) }}
        {{ form_errors(form.kitchen) }}
        {{ form_errors(form.occasion) }}
        {% for key,choice in dietChoices %}
            {{ form_errors(attribute(form, choice)) }}
        {% endfor %}
        {{ form_errors(form.sort) }}
    </div>
    <br>
    {{ form_start(form) }}
    {{ form_widget(form.title, {'id': 'recipe-search'}) }}<i
        id="recipe-filter-icon" class="fas fa-sliders-h"></i>
    <i id="recipe-search-icon" class="fas fa-search"></i>{{ form_widget(form.show, {'attr': {'class': 'd-none'}}) }}
    <div id="filter-sort-div" class="d-none">
        {{ form_widget(form.typeOfDish) }}
        {{ form_widget(form.cookingTime) }}
        {{ form_widget(form.kitchen) }}
        {{ form_widget(form.occasion) }}
        <div class="dropdown" id="diet">
            <div class="form-control form-select" id="diet-filter" role="button"
                 data-bs-toggle="dropdown" aria-expanded="false">Dieet</div>
            <table class="dropdown-menu dropdown-diet" aria-labelledby="diet-filter">
                {% for key, choice in dietChoices %}
                    <tr>
                        <td>{{ form_label(attribute(form, choice)) }}</td>
                        <td>{{ form_widget(attribute(form, choice)) }}</td>
                    </tr>
                {% endfor %}
            </table>
        </div>
        {{ form_widget(form.sort) }}
    </div>
    {{ form_end(form) }}
    <br>
    {% if not isFiltered %}
        <h2 id="recent-recipes-heading">Recente recepten</h2>
    {% endif %}
    <table class="table table-striped" id="recipes-homepage">
        {% for recipe in paginator.results %}
            <tr>
                <td>
                    {% if recipe.imageExtension is not null %}
                        <img src="{{ asset(recipe.getImagePath(appEnv, 100)) }}"
                             alt="label" class="img-fluid recipe-image">
                    {% endif %}
                </td>
                <td><a href="{{ path('recipeSingle', {'id': recipe.id}) }}">{{ recipe.title }}</a></td>
                {% if recipe.rating is null %}
                    <td></td>
                {% else %}
                    <td>
                        <span class="nowrap">{{ recipe.rating|number_format(1) }} <i
                                    class="fas fa-star fa-star-gold"></i></span>
                    </td>
                {% endif %}
            </tr>
        {% endfor %}
    </table>
    {% if isFiltered %}
        {{ include('pagination/view.html.twig', {route: 'homepageIndexPaginated'}) }}
    {% endif %}
{% endblock %}
