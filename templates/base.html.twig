<!DOCTYPE html>
<html lang="nl">
<head>
    <title>{% block title %}{% endblock %}</title>
    {{ include('head.html.twig') }}
</head>
<body>
<div id="smuldieet-header"><img alt="Logo" id="smuldieet-logo" src="{{ asset('/img/Logo_100.jpg') }}">
    <h1 id="smuldieet-title">Smuldieet</h1></div>
<nav class="navbar navbar-expand-lg navbar-light bg-light">
    <div class="container-fluid">
        <button class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbar-supported-content"
                aria-controls="navbar-supported-content"
                aria-expanded="false"
                aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbar-supported-content">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li><a href="{{ path('homepage') }}">Home</a></li>
                <li><a href="{{ path('appLogin') }}"><i class="fas fa-user"></i></a></li>
                <li><a href="{{ path('contact') }}">Contact</a></li>
                <li><a href="{{ path('foodstuff') }}">Voedingsmiddelen</a></li>
                <li><a href="{{ path('diary') }}">Dagboek</a></li>
                <li><a href="{{ path('recipe') }}">Recepten</a></li>
                <li><a href="{{ path('overview') }}">Overzicht</a></li>
            </ul>
            <div id="navigation-border"></div>
            {% block navlist %}{% endblock %}
        </div>
    </div>
</nav>
{% block body %}
{% endblock %}
{% if reCaptchaKey is defined %}
    <script src="https://www.google.com/recaptcha/api.js?render={{ reCaptchaKey }}"></script>
    <div id="re-captcha-key" data-key="{{ reCaptchaKey }}"></div>
{% endif %}
<script src="{{ asset('js/jquery.min.js') }}"></script>
<script src="{{ asset('js/bootstrap.bundle.min.js') }}"></script>
<script src="{{ asset('/js/app.min.js') }}"></script>
<script src="{{ asset('/js/FoodForm.min.js') }}"></script>
{% block javascripts %}
{% endblock %}
</body>
</html>
