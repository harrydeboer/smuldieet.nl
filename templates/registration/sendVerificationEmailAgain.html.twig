{% extends 'base.html.twig' %}

{% block title %}Verify{% endblock %}

{% block body %}
    {% if success is not null %}
        <div class="successMessage">{{ success }}</div>
    {% endif %}
    {% if error is not null %}
        <div class="errorMessage">{{ error }}</div>
    {% endif %}
    {% if success is null %}
        <div>Je e-mail is niet geverifieerd. Check je inbox of
            {{ form_start(form) }}
            {{ form_widget(form.sendEmailAgain, {'label': 'Verstuur opnieuw'}) }}
            {{ form_end(form) }}</div>
    {% endif %}
{% endblock %}
