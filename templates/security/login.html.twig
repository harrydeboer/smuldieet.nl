{% extends 'base.html.twig' %}

{% block title %}Inloggen{% endblock %}

{% block body %}
    {% if isLoggedIn %}
        <span class="no-wrap">Je bent ingelogd als {{ username }},
            <a href="{{ path('appLogout') }}">klik hier</a> om uit te loggen.</span>
        <span class="no-wrap">Verander <a href="{{ path('changePassword') }}">hier</a> je wachtwoord.</span>

        {% if 'ROLE_ADMIN' in roles  %}
            <span class="no-wrap">Ga naar het <a href="{{ path('adminHomepage') }}">Admin Panel</a>.</span>
        {% endif %}
    {% else %}
        <h1 class="h3 mb-3 font-weight-normal">Inloggen</h1>
        <div id="formErrorsClient"></div>
        <div id="formErrorsServer">
            {{ form_errors(form) }}
            {{ form_errors(form.email) }}
            {{ form_errors(form.password) }}
        </div>
        {{ form_start(form) }}
        {% if error %}
            <div>{{ error.messageKey|trans(error.messageData, 'security', 'nl') }}</div>
        {% endif %}
        <table id="loginTable" class="table tableSmall">
            <tr><td>E-mail</td><td>{{ form_widget(form.email,
                        {'value' : last_username}) }}</td></tr>
            <tr><td>Wachtwoord</td><td>{{ form_widget(form.password) }}</td></tr>
            <tr><td colspan="2">{{ form_widget(form.login, {'label': 'Inloggen'}) }}</td></tr>
        </table>
        {{ form_end(form) }}
        <span class="no-wrap">Niet geregistreerd? Ga naar <a href="{{ path('appRegister') }}">deze</a> link.</span>
    {% endif %}
{% endblock %}
