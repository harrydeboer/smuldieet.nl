{% extends 'base.html.twig' %}

{% block title %}Inloggen{% endblock %}

{% block body %}
    {% if isLoggedIn %}
        <h1 class="h3 mb-3 font-weight-normal">Je bent ingelogd als {{ username }},
            <a href="{{ path('appLogout') }}">klik hier om uit te loggen</a></h1>
        <h3>Verander <a href="{{ path('changePassword') }}">hier</a> je wachtwoord.</h3>

        {% if 'ROLE_ADMIN' in roles  %}
            Ga naar het <a href="{{ path('adminHomepage') }}">Admin Panel</a>.
        {% endif %}
    {% else %}
        <h1 class="h3 mb-3 font-weight-normal">Inloggen</h1>
        <div id="formErrorsClient"></div>
        <div id="formErrorsServer">
            {{ form_errors(form) }}
            {{ form_errors(form.email) }}
            {{ form_errors(form.password) }}
        </div>
        {{ form_start(form) }}
        {% if error %}
            <div>{{ error.messageKey|trans(error.messageData, 'security', 'nl') }}</div>
        {% endif %}
        <table id="loginTable">
            <tr><td>Email</td><td>{{ form_widget(form.email,
                        {'value' : last_username}) }}</td></tr>
            <tr><td>Wachtwoord</td><td>{{ form_widget(form.password) }}</td></tr>
            <tr><td colspan="2">{{ form_widget(form.login, {'label': 'Inloggen'}) }}</td></tr>
        </table>
        {{ form_end(form) }}
        Niet geregistreerd? Ga naar <a href="{{ path('appRegister') }}">deze</a> link.
    {% endif %}
{% endblock %}
