{% extends 'base.html.twig' %}

{% block title %}Voedingsmiddel{% endblock %}

{% block content %}
    <table class="table table-small">
        <tr>
            <td>Naam</td>
            <td>{{ foodstuff.name }}</td>
        </tr>
        {% if isLoggedIn %}
            {% if foodstuff.pieceWeight is not null %}
                <tr>
                    <td>Gewicht per stuk (g)</td>
                    <td>{{ foodstuff.pieceWeight }}</td>
                </tr>
            {% endif %}
            {% if foodstuff.pieceName is not null %}
                <tr>
                    <td>Naam per stuk</td>
                    <td>{{ foodstuff.pieceName }}</td>
                </tr>
            {% endif %}
            {% for nutrient in nutrients %}
                <tr>
                    <td>{{ nutrient.displayName }} {{ nutrient.unit }}</td>
                    {% if attribute(foodstuff, nutrient.name) is null %}
                        <td>N/B</td>
                    {% else %}
                        <td>{{ attribute(foodstuff, nutrient.name)|number_format(nutrient.decimalPlaces) }}</td>
                    {% endif %}
                </tr>
            {% endfor %}
        {% else %}
            <tr>
                <td colspan="2"><a href="{{ path('app_login') }}">Log in om alle waarden te zien.</a></td>
            </tr>
        {% endif %}
        <tr>
            <td colspan="2">
                {% if foodstuff.user is not null %}
                    <a href="{{ path('foodstuff_edit', {'id': foodstuff.id}) }}">wijzig</a>
                {% endif %}
            </td>
        </tr>
    </table>
{% endblock %}
