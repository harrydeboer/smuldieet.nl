{% extends 'base.html.twig' %}

{% block title %}Kookboeken{% endblock %}

{% block body %}
    <h1>Kookboeken</h1>
    <a href="{{ path('cookbookCreate') }}">Maak een kookboek</a>
    {% if cookbooks is empty %}
        <p>Je hebt nog geen kookboeken gemaakt.</p>
    {% else %}
        <table class="table table-striped">
            <thead>
            <tr>
                <th scope="col">Titel</th>
                <th scope="col">Wijzig</th>
            </tr>
            </thead>
            {% for cookbook in cookbooks %}
                <tr>
                    <td><a href="{{ path('cookbookSingle', {'id': cookbook.id}) }}">{{ cookbook.title }}</a></td>
                    <td><a href="{{ path('cookbookEdit', {'id': cookbook.id }) }}">wijzig</a></td>
                </tr>
            {% endfor %}
        </table>
    {% endif %}
{% endblock %}
