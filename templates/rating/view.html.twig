{% extends 'base.html.twig' %}

{% block title %}Waarderingen{% endblock %}

{% block body %}
    <h1>Waarderingen</h1>
    <table class="table table-striped">
        <thead>
        <tr>
            <th scope="col">Waardering</th>
            <th scope="col">Wijzig</th>
        </tr>
        </thead>
        {% for rating in ratings %}
            <tr>
                <td><a href="{{ path('rating_single', {'id': rating.id}) }}">{{ rating.rating }}</a></td>
                <td><a href="{{ path('rating_edit', {'id': rating.id }) }}">wijzig</a></td>
            </tr>
        {% endfor %}
    </table>
{% endblock %}
