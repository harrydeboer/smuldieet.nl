{% extends 'base.html.twig' %}

{% block title %}{{ page is not null ? page.title : '' }}{% endblock %}

{% block body %}
    <h1>Dagen</h1>
    <div><a href="{{ path('dayCreate') }}">Maak een dag</a></div>
    {% if standardDay is null %}
        {{ page is not null ? page.content|raw : '' }}
    {% else %}
        <br>
    {% endif %}
    {% if standardDay is not null %}
        <div><a href="{{ path('dayEdit', {'id': standardDay.id}) }}">Wijzig de standaard dag</a></div>
    {% else %}
        <div><a href="{{ path('dayCreateStandard') }}">Maak de standaard dag</a></div>
    {% endif %}
    {% if paginator.results is empty %}
        <br><p>Er zijn nog geen dagen toegevoegd aan je dagboek.</p>
    {% else %}
        <table class="table table-striped">
            <thead>
            <tr>
                <th scope="col">Datum</th>
                <th scope="col">Wijzig</th>
            </tr>
            </thead>
            {% for day in paginator.results %}
                <tr>
                    <td><a href="{{ path('daySingle', {'id': day.id}) }}">{{ day.date }}</a></td>
                    <td><a href="{{ path('dayEdit', {'id': day.id }) }}">wijzig</a></td>
                </tr>
            {% endfor %}
        </table>
        {{ include('pagination/view.html.twig', {route: 'diaryIndexPaginated'}) }}
    {% endif %}
{% endblock %}
