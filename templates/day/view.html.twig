{% extends 'base.html.twig' %}

{% block title %}Dagen{% endblock %}

{% block body %}
    <h1>Dagen</h1>
    {% if standardDay is null %}
        {{ page.content|raw }}
    {% endif %}
    <a href="{{ path('dayCreate') }}">Maak een dag</a>
    {% if standardDay is not null %}
        <a href="{{ path('dayEdit', {'id': standardDay.id}) }}">Wijzig de standaard dag</a>
    {% else %}
        <a href="{{ path('dayCreateStandard') }}">Maak de standaard dag</a>
    {% endif %}
    {% if paginator.results is empty %}
        <p>Er zijn nog geen dagen toegevoegd aan je dagboek.</p>
    {% else %}
        <table class="table table-striped">
            <thead>
            <tr>
                <th scope="col">Datum</th>
                <th scope="col">Wijzig</th>
            </tr>
            </thead>
            {% for day in paginator.results %}
                <tr>
                    <td><a href="{{ path('daySingle', {'id': day.id}) }}">{{ day.date }}</a></td>
                    <td><a href="{{ path('dayEdit', {'id': day.id }) }}">wijzig</a></td>
                </tr>
            {% endfor %}
        </table>
        {{ include('pagination/view.html.twig', {route: 'dayIndexPaginated'}) }}
    {% endif %}
{% endblock %}
