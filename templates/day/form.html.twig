<div id="form-errors-client"></div>
<div id="form-errors-server">
    {{ form_errors(form) }}
</div>
{{ form_start(form, { 'attr' : { 'class': 'foodstuff-recipe-form' }}) }}
{% if form.date is defined %}
    {{ form_errors(form.date) }}
{% endif %}
<table class="foodstuff-recipe-table table table-small">
    {% if form.date is defined %}
        <tr><td>Datum</td><td colspan="2">{{ form_widget(form.date) }}</td></tr>
        {% set formName = 'day' %}
    {% else %}
        {% set formName = 'standard_day' %}
    {% endif %}
    {% for rowId, foodstuff in day.foodstuffs %}
        {{ include('foodstuffRow.html.twig', {'rowId': rowId + 1, 'formName': formName,
            'id': foodstuff.id, 'name': foodstuff.name, 'weight': day.foodstuffWeights[foodstuff.id]}) }}
    {% endfor %}
    {% for rowId, recipe in day.recipes %}
        {% set rowIdRecipe = rowId + day.foodstuffs.count + 1 %}
        {{ include('recipeRow.html.twig', {'rowId': rowIdRecipe, 'formName': formName,
            'id': recipe.id, 'title': recipe.title, 'weight': day.recipeWeights[recipe.id]}) }}
    {% endfor %}
    <tr id="add-foodstuff-recipe-button-row"><td colspan="3">
            <button class="btn btn-primary" id="add-foodstuff">Voedingsmiddel toevoegen</button>
            <button class="btn btn-primary" id="add-recipe">Recept toevoegen</button></td></tr>
    <tr><td colspan="3">{{ form_widget(form.submit, { 'label': submitLabel }) }}</td></tr>
</table>
<div class="d-none">
    {{ form_widget(form.foodstuffWeights) }}
    {{ form_widget(form.recipeWeights) }}
</div>
{{ form_end(form) }}
