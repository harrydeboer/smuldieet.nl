{% extends 'base.html.twig' %}

{% block title %}Day{% endblock %}

{% block body %}
    <table class="table">
        {% if day.date is not null %}
            <tr><td>Datum</td><td>{{ day.date }}</td></tr>
        {% endif %}
        {% for rowNumber, foodstuff in day.foodstuffs %}
            <tr id="row{{ rowNumber + 1 }}">
                <td>{{ foodstuff.name }}</td>
                <td>{{ day.foodstuffWeights[foodstuff.id]|number_format }}</td>
            </tr>
        {% endfor %}
        {% for rowNumber, recipe in day.recipes %}
            {% set rowNumberRecipe = rowNumber + day.foodstuffs.count %}
            <tr id="row{{ rowNumberRecipe + 1 }}">
                <td>{{ recipe.title }}</td>
                <td>{{ day.recipeWeights[recipe.id]|number_format }}</td>
            </tr>
        {% endfor %}
        <tr><td colspan="2"><a href="{{ path('dayEdit', {'id': day.id}) }}">wijzig</a></td></tr>
    </table>
{% endblock %}
