{% extends 'base.html.twig' %}

{% block title %}{{ page is not null ? page.title : '' }}{% endblock %}

{% block body %}
    {{ page is not null ? page.content|raw : '' }}
    <div id="form-errors-client"></div>
    <div id="form-errors-server">
        {{ form_errors(form) }}
        {{ form_errors(form.name) }}
        {{ form_errors(form.subject) }}
        {{ form_errors(form.email) }}
        {{ form_errors(form.message) }}
    </div>
    {% if success is null and error is null %}
    {% elseif success %}
        <div class="success-message">{{ success }}</div>
    {% elseif error %}
        <div class="error-message">{{ error }}</div>
    {% endif %}
    {{ form_start(form) }}
    <table id="contact-table" class="table table-small">
        <tr><td>Naam</td><td>{{ form_widget(form.name) }}</td></tr>
        <tr><td>Onderwerp</td><td>{{ form_widget(form.subject) }}</td></tr>
        <tr><td>E-mail</td><td>{{ form_widget(form.email) }}</td></tr>
        <tr><td>Bericht</td><td>{{ form_widget(form.message) }}</td></tr>
        <tr><td colspan="2">{{ form_widget(form.send, { 'label': 'Verzenden' }) }}</td></tr>
    </table>
    {{ form_widget(form.reCaptchaToken, {'id': 'contact-re-captcha-token'}) }}
    {{ form_end(form) }}
{% endblock %}
